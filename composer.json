{
    "name": "kyleclarkenz/manhattan",
    "description": "Manhattan — a server-rendered PHP + vanilla-JS UI component library.",
    "type": "library",
    "license": "MIT",
    "version": "1.27.4",
    "keywords": ["ui", "components", "php", "javascript", "framework"],
    "authors": [
        {
            "name": "Kyle Clarke",
            "homepage": "https://github.com/KyleClarkeNZ"
        }
    ],
    "require": {
        "php": ">=7.4",
        "components/font-awesome": "^6.5"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Manhattan\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
